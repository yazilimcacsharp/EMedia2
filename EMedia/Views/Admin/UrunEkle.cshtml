@model EMedia.Models.Product

@{
    Layout = "_LayoutAdmin";
}

<h2>Ürün Ekle</h2>

<form asp-action="UrunEkle" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="Name" class="control-label">Ürün Adı</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="SubCategoryId" class="control-label">Alt Kategori</label>
        <select asp-for="SubCategoryId" class="form-control" asp-items="ViewBag.SubCategories"></select>
        <span asp-validation-for="SubCategoryId" class="text-danger"></span>
    </div>

    <div class="form-group form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Aktif mi?</label>
    </div>

    <div class="form-group">
        <label asp-for="Price" class="control-label">Fiyat</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CreatedDate" class="control-label">Eklenme Tarihi</label>
        <input asp-for="CreatedDate" type="date" class="form-control" />
        <span asp-validation-for="CreatedDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Stock" class="control-label">Stok Adedi</label>
        <input asp-for="Stock" class="form-control" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label class="control-label">Fotoğraf</label>
        <input type="file" name="foto" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
